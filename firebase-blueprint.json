{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Public user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "opinion": { "type": "string", "enum": ["Pro Israel", "Pro Palestine", "Neutral"] },
        "isBanned": { "type": "boolean" },
        "isAdmin": { "type": "boolean" }
      },
      "required": ["uid", "displayName", "opinion"]
    },
    "UserPrivate": {
      "title": "UserPrivate",
      "description": "Private user data",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "age": { "type": "number" },
        "reportsCount": { "type": "number" },
        "banUntil": { "type": "string", "format": "date-time" },
        "banReason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "age"]
    },
    "DebateSession": {
      "title": "DebateSession",
      "description": "A debate session between two users",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "ended"] },
        "startTime": { "type": "string", "format": "date-time" },
        "aiVerifications": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "claim": { "type": "string" },
              "verification": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        }
      }
    },
    "Signal": {
      "title": "Signal",
      "description": "WebRTC signaling data",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "data": { "type": "string" },
        "senderId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Report": {
      "title": "Report",
      "description": "User report for misconduct",
      "type": "object",
      "properties": {
        "reporterId": { "type": "string" },
        "reportedId": { "type": "string" },
        "reason": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Ban": {
      "title": "Ban",
      "description": "A manual ban record",
      "type": "object",
      "properties": {
        "adminId": { "type": "string" },
        "bannedId": { "type": "string" },
        "reason": { "type": "string" },
        "durationHours": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      }
    },
    "QueueEntry": {
      "title": "QueueEntry",
      "description": "User waiting for a match",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "opinion": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/profiles/{userId}": {
      "schema": "UserProfile",
      "description": "Public user profiles"
    },
    "/users/{userId}": {
      "schema": "UserPrivate",
      "description": "Private user data"
    },
    "/debates/{debateId}": {
      "schema": "DebateSession",
      "description": "Active and past debate sessions"
    },
    "/debates/{debateId}/signals/{signalId}": {
      "schema": "Signal",
      "description": "WebRTC signals for a debate"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "User reports"
    },
    "/bans/{banId}": {
      "schema": "Ban",
      "description": "Manual ban logs"
    },
    "/queue/{userId}": {
      "schema": "QueueEntry",
      "description": "Matching queue"
    }
  }
}
